{
  "openapi": "3.0.0",
  "info": {
    "title": "Volunteer API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://hackaton-ai-2026.vercel.app"
    }
  ],
  "paths": {
    "/api/user-profile": {
      "get": {
        "summary": "Get logged user profile",
        "responses": {
          "200": {
            "description": "User profile",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "skills": {
                      "type": "array",
                      "items": { "type": "string" }
                    },
                    "location": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/opportunities": {
      "get": {
        "summary": "Get volunteer opportunities",
        "responses": {
          "200": {
            "description": "List of opportunities",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "opportunities": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "title": { "type": "string" },
                          "location": { "type": "string" },
                          "skills_required": {
                            "type": "array",
                            "items": { "type": "string" }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}