generator client {
  provider = "prisma-client-js"
  output   = "../src/lib/prisma/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Volunteer {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String

  name          String
  location      String
  availability  String
  description   String
  skills        String[]

  createdAt     DateTime @default(now())
}